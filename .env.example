# Zenway (RailMind Sentinel) - Environment Configuration

# Optional: API Key for live Gemini 1.5 Flash Action Card generation.
# If omitted, Zenway falls back to local pre-cached responses for Judge Demo Mode.
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: API Key for Bhashini Translations.
# If omitted, Zenway falls back to local pre-cached translations.
BHASHINI_API_KEY=your_bhashini_api_key_here

# Backend settings
PORT=8000
HOST=0.0.0.0
APP_ENV=development
